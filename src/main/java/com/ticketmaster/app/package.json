{
  "name": "ticketwatch",
  "version": "1.0.0",
  "description": "Ticketmaster seat availability monitor",
  "main": "main.js",
  "author": "TicketWatch",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.ticketwatch.app",
    "productName": "TicketWatch",
    "copyright": "Copyright © 2025",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "../backend/dist/task.exe",
        "to": "backend/task.exe"
      }
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "shortcutName": "TicketWatch"
    }
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  }
}